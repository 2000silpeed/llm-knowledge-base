# ──────────────────────────────────────────────
# LLM 지식 베이스 — 환경변수 템플릿
# 이 파일을 .env 로 복사한 뒤 값을 채워 넣으세요.
# cp .env.example .env
# ──────────────────────────────────────────────

# ── LLM API 키 (사용하는 provider 것만 설정) ──

# Anthropic (기본)
ANTHROPIC_API_KEY=sk-ant-...

# Z.ai (GLM)
# Z_AI_API_KEY=your-z-ai-key

# Groq
# GROQ_API_KEY=your-groq-key

# Together AI
# TOGETHER_API_KEY=your-together-key

# ── 웹 UI 설정 ──

# wiki 디렉토리 절대 경로 (기본: 프로젝트 루트의 wiki/)
# KB_WIKI_DIR=/absolute/path/to/wiki

# Next.js 포트 (기본: 3000)
# PORT=3000

# ── 모바일 클리퍼 (P3-02) ──

# 프로젝트 루트 경로 (기본: web/ 의 부모 디렉토리)
# KB_PROJECT_DIR=/absolute/path/to/project

# 클리퍼 API 인증키 (설정 시 X-KB-Key 헤더 또는 Bearer 토큰 필요)
# 공개 서버에 배포할 경우 반드시 설정하세요.
# KB_CLIP_KEY=your-secret-key-here

# ── 외부 연동 API 서버 (P3-04) ──

# API 서버 호스트/포트 (기본: 0.0.0.0:8000)
# KB_API_HOST=0.0.0.0
# KB_API_PORT=8000

# API 키 인증 활성화 여부 (기본: true)
# 로컬 전용 환경에서만 false 로 설정. 외부 공개 시 반드시 true.
# KB_API_KEYS_ENABLED=true

# CORS 허용 오리진 (쉼표 구분, 기본: * 전체 허용)
# 실서비스 시 도메인을 명시하세요.
# KB_API_CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
