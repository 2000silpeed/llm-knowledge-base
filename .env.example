# ──────────────────────────────────────────────
# LLM 지식 베이스 — 환경변수 템플릿
# 이 파일을 .env 로 복사한 뒤 값을 채워 넣으세요.
# cp .env.example .env
# ──────────────────────────────────────────────

# ── LLM API 키 (사용하는 provider 것만 설정) ──

# Anthropic (기본)
ANTHROPIC_API_KEY=sk-ant-...

# Z.ai (GLM)
# Z_AI_API_KEY=your-z-ai-key

# Groq
# GROQ_API_KEY=your-groq-key

# Together AI
# TOGETHER_API_KEY=your-together-key

# ── 웹 UI 설정 ──

# wiki 디렉토리 절대 경로 (기본: 프로젝트 루트의 wiki/)
# KB_WIKI_DIR=/absolute/path/to/wiki

# Next.js 포트 (기본: 3000)
# PORT=3000
